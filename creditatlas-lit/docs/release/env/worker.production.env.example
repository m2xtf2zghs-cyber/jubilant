# Runtime
ENVIRONMENT=production

# Security
SECRET_KEY=replace-with-strong-random-secret

# Database
POSTGRES_DB=creditatlas
POSTGRES_USER=creditatlas
POSTGRES_PASSWORD=replace-with-db-password
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
DATABASE_URL_OVERRIDE=

# Redis / Celery
REDIS_URL=redis://your-redis-host:6379/0
CELERY_BROKER_URL=redis://your-redis-host:6379/0
CELERY_RESULT_BACKEND=redis://your-redis-host:6379/1
ALLOW_INLINE_INGESTION_FALLBACK=false

# Object Storage
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://your-s3-endpoint
S3_ACCESS_KEY=replace-with-access-key
S3_SECRET_KEY=replace-with-secret-key
S3_REGION=us-east-1
S3_BUCKET=creditatlas-docs
S3_SECURE=true
