# Web app auth modes (Vite build-time config)
# Option A (recommended): Backend auth + dashboard API mode
# Option B: Demo frontend-only login (fallback)

# ---- Option A: Backend mode ----
# Example: http://localhost:8787 for local backend
VITE_API_BASE_URL=
# Optional: prefill/send organizationCode during login (for multi-org setups)
VITE_BACKEND_ORG_CODE=

# ---- Option B: Demo mode ----
# NOTE: These are embedded in the built frontend bundle and are NOT secure for real production auth.
# Use backend auth mode for real usage.

VITE_DEMO_USERNAME=your_demo_username
VITE_DEMO_PASSWORD=your_demo_password
