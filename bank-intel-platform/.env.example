APP_NAME=Bank Intel Platform
ENV=dev
DATABASE_URL=sqlite:///./bank_intel.db
UPLOAD_DIR=./data/uploads
EXPORT_DIR=./data/exports
CONFIG_DIR=./app/config
LOG_LEVEL=INFO
ENABLE_CONSOLE=true
ENFORCE_HTTPS_REDIRECT=false
TRUSTED_HOSTS=*
PROXY_HEADERS_ENABLED=true
PROXY_TRUSTED_IPS=*
MAX_UPLOAD_MB=50
MAX_FILES_PER_JOB=12
AUTH_BEARER_TOKENS=
AUTH_EXEMPT_PATHS=/,/health,/api/health,/api/health/ready
AUDIT_LOG_DB_ENABLED=true
PUBLIC_BASE_URL=
REMOTE_PARSE_BASE_URL=
REMOTE_PARSE_API_KEY=
REMOTE_PARSE_TIMEOUT_SEC=180
